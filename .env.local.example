# Local development environment — copy to .env and fill in your DEV values
# These should point to separate dev resources so local testing never touches production data.

GEMINI_API_KEY=your_gemini_api_key_here

# Dev Discord bot token (create a second bot at discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_dev_discord_bot_token_here

# Dev Discord channel (e.g. hsa-receipts-dev)
DISCORD_CHANNEL_NAME=hsa-receipts-dev

# Dev Google Drive folder ID (create a folder called HSSave-Dev in Drive, copy ID from URL)
GOOGLE_DRIVE_FOLDER_ID=your_dev_drive_folder_id_here

# Dev Google Sheet ID (create a sheet called HSSave-Dev, copy ID from URL)
GOOGLE_SHEETS_ID=your_dev_google_sheet_id_here
